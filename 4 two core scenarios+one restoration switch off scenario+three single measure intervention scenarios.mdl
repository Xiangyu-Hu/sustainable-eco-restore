K growth=0
	~	
	~		|

K infil=0
	~	
	~		|

r eff=r*(1+K growth*Interv)
	~	
	~		|

"infil c,eff"=infil c*(1+K infil*Interv)
	~	
	~		|

Infiltration="infil c,eff"*P norm*(1-Soil Water)
	~	mm/Month
	~		|

d1 eff=d1*(1-K deg*Interv)
	~	
	~		|

Degradation=Vegetation Biomass*(d0+d1 eff*(1-Soil Water))
	~	
	~		|

t start=144
	~	
	~		|

SCEN=1
	~	
	~		|

Growth=r eff*Vegetation Biomass*(1-Vegetation Biomass)*(Soil Water/(Soil Water+S half\
		))+g0*(Soil Water/(Soil Water+S half))
	~	
	~		|

K deg=0.25
	~	
	~		|

Interv=SCEN*MIN (1, MAX (0,(Time-t start)/t ramp) )
	~	
	~		|

t ramp=12
	~	
	~		|

a p=0.147308
	~	
	~		|

a v=0.0986245
	~	
	~		|

b=0.0880384
	~	
	~		|

NDVI sim raw=a v*Vegetation Biomass+a p*P norm+b
	~	
	~		|

S half=0.504153
	~	
	~		|

d0=0.0802434
	~	
	~		|

d1=0.35089
	~	
	~		|

Evapotranspiration=Soil Water*Vegetation Biomass*K et
	~	
	~		|

g0=0.00870035
	~	
	~		|

infil c=0.595101
	~	
	~		|

K et=0.0499729
	~	
	~		|

K perc=0.149652
	~	
	~		|

r=0.49543
	~	
	~		|

Percolation=Soil Water*K perc
	~	
	~		|

NDVI sim=MAX ( 0 , MIN ( 1 , SMOOTH ( NDVI sim raw , 1 ) ) )
